{
    "name": "passcore",
    "version": "1.0.0",
    "description": "PassCore is a self-service password change utility for Active Directory.",
    "source": "index.html",
    "scripts": {
        "lint": "tsc --noEmit && eslint ./**/*.{js,ts,tsx}  --quiet",
        "lint:fix": "eslint ./**/*.{js,ts,tsx}  --quiet --fix",
        "build": "parcel build index.html --dist-dir ../wwwroot --log-level warn",
        "build:tsc": "tsc",
        "prettier": "prettier --check ./**/*.ts*",
        "prettier:fix": "prettier --write ./**/*.ts*",
        "start": "parcel index.html --dist-dir ../wwwroot --open --port 4040"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/EastCentralRegionalLibrary/passcore.git"
    },
    "author": "Unosquare",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/EastCentralRegionalLibrary/passcore/issues"
    },
    "homepage": "https://github.com/EastCentralRegionalLibrary/passcore",
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^9.0.0",
        "@mui/material": "^9.0.0",
        "@zxcvbn-ts/core": "^3.0.4",
        "@zxcvbn-ts/language-common": "^3.0.4",
        "@zxcvbn-ts/language-en": "^3.0.2",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/zxcvbn": "^4.4.0",
        "eslint": "^9.39.4",
        "eslint-plugin-react": "^7.37.5",
        "globals": "^16.5.0",
        "minimist": "^1.2.8",
        "parcel": "^2.16.4",
        "parcel-plugin-clean-easy-unsafe": "^1.0.2",
        "prettier": "^3.8.3",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.58.2"
    },
    "parcelCleanPaths": [
        "../wwwroot"
    ],
    "parcelCleanUnsafePaths": true
}
